# Copia este archivo como .env y completa con tu proyecto Supabase:
# https://supabase.com/dashboard → Project Settings → API
#
# En Vercel: Project Settings → Environment Variables (mismos nombres).
# El build genera public/cloud-config.json con estas variables.

VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU_ANON_KEY_PUBLICA
